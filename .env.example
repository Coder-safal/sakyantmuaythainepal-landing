NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_ASSET_BASE_URL=http://localhost:3000

# Contact numbers — change these in .env.local
# Phone shown on site (free format, e.g. "+977 98XX XXXXXX")
NEXT_PUBLIC_CONTACT_PHONE=+977 98XX XXXXXX
# WhatsApp number — DIGITS ONLY, with country code, no + or spaces (e.g. 9779800000000)
NEXT_PUBLIC_WHATSAPP_NUMBER=9779800000000
# Viber number — DIGITS ONLY, with country code, no + or spaces (e.g. 9779800000000)
NEXT_PUBLIC_VIBER_NUMBER=9779800000000
